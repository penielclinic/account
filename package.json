{
  "name": "eum-accounting",
  "version": "0.1.0",
  "description": "해운대순복음교회 이음 회계 모듈",
  "private": true,
  "main": ".electron/main.js",
  "scripts": {
    "dev:next": "cross-env BROWSER=none next dev -p 3001",
    "dev:electron": "wait-on http://localhost:3001 && tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electronmon .electron/main.js",
    "dev": "concurrently -k --names \"NEXT,ELECTRON\" --prefix-colors \"blue,magenta\" \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:win": "npm run build:next && npm run build:electron && electron-builder --win",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tanstack/react-query": "^5.40.0",
    "@tremor/react": "^3.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx": "^8.5.0",
    "electron-updater": "^6.2.1",
    "exceljs": "^4.4.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.400.0",
    "next": "^14.2.4",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.9",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.1.2",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
"typescript": "^5.5.3",
    "vitest": "^2.0.2",
    "wait-on": "^7.2.0"
  }
}
